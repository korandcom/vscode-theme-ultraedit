{
  "$schema": "vscode://schemas/color-theme",
  "name": "Ultraedit Light",
  "type": "light",
  "colors": {
    // Editor

    "editor.background": "#FFFFFF",
    "editor.foreground": "#000000",
    "editor.lineHighlightBackground": "#f6f8fa",
    "editorLineNumber.foreground": "#999999",

    // Selection

    "editor.selectionBackground": "#BFDFFF",
    "editor.selectionHighlightBackground": "#BFDFFF60",
    "editor.inactiveSelectionBackground": "#BFDFFF90",

    // Find

    "editor.findMatchBackground": "#BFDFFF90",
    "editor.findMatchHighlightBackground": "#BFDFFF00",
    "editor.findRangeHighlightBackground": "#BFDFFF40",
    "editor.findMatchHighlightBorder": "#00000060",

    // Title bar

    "titleBar.activeBackground": "#404858",
    "titleBar.activeForeground": "#ECEFF4",
    "titleBar.border": "#404858",

    // Activity bar

    "activityBar.background": "#2B303B",
    "activityBar.border": "#2B303B",

    // Side bar

    "sideBar.background": "#F6F8FA",
    "sideBar.border": "#E1E4E8",
    "sideBarSectionHeader.background": "#F6F8FA",
    "sideBarSectionHeader.border": "#E1E4E8",

    // Panel (terminal, output, problems, etc.)

    "panel.background": "#ECF0F4",
    "panel.border": "#E1E4E8",
    "panelTitle.activeBorder": "#4B83CDCC",

    // Status bar

    "statusBar.background": "#404858",
    "statusBar.foreground": "#ECEFF4",
    "statusBar.border": "#303848",

    // Tabs

    "editorGroupHeader.tabsBackground": "#E1E4E8",
    "editorGroupHeader.tabsBorder": "#CACED4",
    "tab.border": "#CACED4",
    "tab.activeBackground": "#FFFFFF",
    "tab.activeForeground": "#303848",
    "tab.inactiveBackground": "#E1E4E8",
    "tab.inactiveForeground": "#606878",
    "tab.activeBorder": "#FFFFFF",

    // Inputs

    "input.background": "#FFFFFF",
    "input.foreground": "#000000",
    "input.border": "#C8CBD5",
    "dropdown.background": "#FFFFFF",
    "dropdown.foreground": "#000000",
    "dropdown.border": "#C8CBD5",
    "checkbox.background": "#FFFFFF",
    "checkbox.foreground": "#000000",
    "checkbox.border": "#C8CBD5",
    "focusBorder": "#7A8AA4",

    // Quick Pick / Command Palette

    "quickInput.background": "#ECF0F4",
    "quickInputList.focusBackground": "#4B83CDCC",
    "pickerGroup.border": "#C8CBD5",

    // List

    "list.activeSelectionBackground": "#4B83CDCC",
    "list.activeSelectionForeground": "#FFFFFF",
    "list.focusHighlightForeground": "#FFFFFF",
    "list.activeSelectionIconForeground": "#FFFFFF",
    "list.inactiveSelectionBackground": "#D0D4E0",
    "list.hoverBackground": "#DDE0E890",

    // Links

    "textLink.foreground": "#0066CC",
    "textLink.activeForeground": "#0080FF",

    // Notifications

    "notifications.background": "#ECF0F4",
    "notifications.border": "#E1E4E8",
    "notificationCenter.border": "#E1E4E8",
    "notificationCenterHeader.background": "#ECF0F4",

    // Scrollbar and shadows

    "editorGroupHeader.border": "#CACED4",
    "scrollbar.shadow": "#6a737d33",
    "scrollbarSlider.background": "#959da533",
    "scrollbarSlider.hoverBackground": "#959da544",
    "scrollbarSlider.activeBackground": "#959da588",
    "editorStickyScroll.border": "#CACED4",
    "editorStickyScroll.shadow": "#00000020",

    // Editor Widget (Ctrl+F search, replace)

    "editorWidget.background": "#ECF0F4",
    "editorWidget.border": "#C8CBD5",

    // Hover / Tooltip

    "editorHoverWidget.background": "#ECF0F4",
    "editorHoverWidget.border": "#C8CBD5",

    // Suggest Widget (autocomplete)

    "editorSuggestWidget.background": "#ECF0F4",
    "editorSuggestWidget.border": "#C8CBD5",
    "editorSuggestWidget.selectedBackground": "#4B83CDCC",
    "editorSuggestWidget.selectedForeground": "#FFFFFF",
    "editorSuggestWidget.highlightForeground": "#303848",

    // Peek View (References, Definitions)

    "peekView.border": "#C8CBD5",
    "peekViewEditor.background": "#FFFFFF",
    "peekViewEditorGutter.background": "#FFFFFF",
    "peekViewResult.background": "#F6F8FA",
    "peekViewResult.selectionBackground": "#4B83CDCC",
    "peekViewResult.matchHighlightBackground": "#BFDFFF90",
    "peekViewEditor.matchHighlightBackground": "#BFDFFF90",
    "peekViewTitle.background": "#F0F1F3",

    // Unused code

    "editorUnnecessaryCode.opacity": "#00000050",

    // Diff / Merge

    "diffEditor.insertedTextBackground": "#a5d6a760",
    "diffEditor.removedTextBackground": "#ef9a9a60",
    "diffEditor.insertedLineBackground": "#c8e6c940",
    "diffEditor.removedLineBackground": "#ffcdd240",
    "diffEditorGutter.insertedLineBackground": "#a5d6a740",
    "diffEditorGutter.removedLineBackground": "#ef9a9a40",
    "diffEditorOverview.insertedForeground": "#a5d6a790",
    "diffEditorOverview.removedForeground": "#ef9a9a90"
  },
  "tokenColors": [

    // Comments

    {
      "scope": "comment",
      "settings": {
        "foreground": "#55A0A0C0"
      }
    },

    // JSDoc tags (@deprecated etc.)

    {
      "scope": [
        "comment storage.type.class.jsdoc",
        "comment punctuation.definition.block.tag.jsdoc"
      ],
      "settings": {
        "foreground": "#FF000090"
      }
    },

    // Strings

    {
      "scope": "string",
      "settings": {
        "foreground": "#686868"
      }
    },

    // Numbers

    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#ff0000"
      }
    },

    // Builtin functions

    {
      "scope": ["support.function"],
      "settings": {
        "foreground": "#804040"
      }
    },

    // Variables

    {
      "scope": ["variable", "meta.definition.variable entity.name.function"],
      "settings": {
        "foreground": "#FF8000"
      }
    },

    // Classes

    {
      "scope": ["entity.name.type.class"],
      "settings": {
        "fontStyle": "bold"
      }
    },

    // Functions

    {
      "scope": [
        "meta.function entity.name.function",
        "meta.function support.function"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },

    {
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call support.function"
      ],
      "settings": {
        "fontStyle": ""
      }
    },

    // Global variables, constants, storage type and etc

    {
      "scope": [
        "variable.other.global",
        "constant",
        "support.constant",
        "storage",
        "keyword"
      ],
      "settings": {
        "foreground": "#0000ff"
      }
    },

    // Decorators

    {
      "scope": [
        "meta.decorator entity.name.function",
        "meta.decorator meta.function-call entity.name.function",
        "meta.decorator punctuation.decorator"
      ],
      "settings": {
        "foreground": "#A16A94"
      }
    },

    // Types

    {
      "scope": [
        "support.type.primitive",
        "meta.type.annotation",
        "meta.return.type",
        "meta.type.parameters"
      ],
      "settings": {
        "foreground": "#5476a0"
      }
    },

    // Regexp

    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#4B83CD"
      }
    },

    // Operators, storage modifiers

    {
      "scope": ["keyword.operator", "storage.modifier"],
      "settings": {
        "foreground": "#008000"
      }
    },

    // PHP

    {
      "scope": [
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php"
      ],
      "settings": {
        "foreground": "#A16A94"
      }
    },

    {
      "scope": ["support.function.construct.php"],
      "settings": {
        "fontStyle": ""
      }
    },

    // HTML/XML

    {
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end",
        "entity.name.tag",
        "entity.name.tag.block.any",
        "entity.name.tag.inline.any"
      ],
      "settings": {
        "foreground": "#0000FF"
      }
    },

    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#FF0000"
      }
    },

    // CSS

    {
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#0000FF"
      }
    },

    {
      "scope": [
        "meta.property-value.css keyword.other.unit",
        "meta.at-rule.media.header.css keyword.other.unit"
      ],
      "settings": {
        "foreground": "#FF0000"
      }
    },

    {
      "scope": [
        "meta.property-value.css support.constant",
        "meta.property-value.css constant"
      ],
      "settings": {
        "foreground": "#FF8000"
      }
    },

    {
      "scope": ["meta.property-value.css support.function"],
      "settings": {
        "fontStyle": ""
      }
    },

    // JSON

    {
      "scope": [
        "punctuation.support.type.property-name.begin.json",
        "punctuation.support.type.property-name.end.json"
      ],
      "settings": {
        "foreground": "#686868"
      }
    },

    {
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#FF8000"
      }
    },

    {
      "scope": ["string.quoted.double.json"],
      "settings": {
        "foreground": "#686868"
      }
    },

    {
      "scope": ["constant.numeric.json"],
      "settings": {
        "foreground": "#FF0000"
      }
    },

    {
      "scope": ["constant.language.json"],
      "settings": {
        "foreground": "#0000FF"
      }
    },

    {
      "scope": [
        "punctuation.definition.dictionary.begin.json",
        "punctuation.definition.dictionary.end.json",
        "punctuation.definition.array.begin.json",
        "punctuation.definition.array.end.json"
      ],
      "settings": {
        "foreground": "#008000"
      }
    },

    // SQL

    {
      "scope": [
        "keyword.other.sql",
        "keyword.other.create.sql",
        "keyword.other.DML.sql",
        "keyword.other.DML.II.sql",
        "keyword.other.postgres",
        "keyword.other.sql.postgres",
        "keyword.control.postgres"
      ],
      "settings": {
        "foreground": "#FF8000"
      }
    }
  ]
}
