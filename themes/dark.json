{
  "$schema": "vscode://schemas/color-theme",
  "name": "Ultraedit Dark",
  "type": "dark",
  "colors": {
    // Editor

    "editor.background": "#1E1E1E",
    "editor.foreground": "#D4D4D4",
    "editor.lineHighlightBackground": "#2A2A1E",
    "editorLineNumber.foreground": "#666666",

    // Selection

    "editor.selectionBackground": "#264F78",
    "editor.selectionHighlightBackground": "#264F7880",
    "editor.inactiveSelectionBackground": "#264F7890",

    // Find

    "editor.findMatchBackground": "#264F7890",
    "editor.findMatchHighlightBackground": "#264F7800",
    "editor.findRangeHighlightBackground": "#264F7840",
    "editor.findMatchHighlightBorder": "#FFFFFF80",

    // Title bar

    "titleBar.activeBackground": "#2D2D2D",
    "titleBar.activeForeground": "#CCCCCC",
    "titleBar.border": "#444444",

    // Activity bar

    "activityBar.background": "#1A1A1A",

    // Side bar

    "sideBar.background": "#252525",

    // Status bar

    "statusBar.background": "#333333",
    "statusBar.foreground": "#CCCCCC",

    // Tabs

    "editorGroupHeader.tabsBackground": "#2D2D2D",
    "tab.border": "#444444",
    "tab.activeBackground": "#1E1E1E",
    "tab.activeForeground": "#D4D4D4",
    "tab.inactiveBackground": "#2D2D2D",
    "tab.inactiveForeground": "#888888",
    "tab.activeBorder": "#1E1E1E",

    // List

    "list.activeSelectionBackground": "#4B83CD",
    "list.activeSelectionForeground": "#EEEEEE",
    "list.focusHighlightForeground": "#FFFFFF",
    "list.activeSelectionIconForeground": "#FFFFFF",

    // Unused code
    "editorUnnecessaryCode.opacity": "#00000070"
  },
  "tokenColors": [
    // Comments

    {
      "scope": "comment",
      "settings": {
        "foreground": "#4EC9B0"
      }
    },

    // Strings

    {
      "scope": "string",
      "settings": {
        "foreground": "#AAAAAA"
      }
    },

    // Numbers

    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#FF6060"
      }
    },

    // Builtin functions

    {
      "scope": ["support.function"],
      "settings": {
        "foreground": "#C08080"
      }
    },

    // Variables

    {
      "scope": ["variable", "meta.definition.variable entity.name.function"],
      "settings": {
        "foreground": "#C8843A"
      }
    },

    // Classes

    {
      "scope": ["entity.name.type.class"],
      "settings": {
        "fontStyle": "bold"
      }
    },

    // Functions

    {
      "scope": [
        "meta.function entity.name.function",
        "meta.function support.function"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },

    {
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call support.function"
      ],
      "settings": {
        "fontStyle": ""
      }
    },

    // Global variables, constants, storage type and etc

    {
      "scope": [
        "variable.other.global",
        "constant",
        "support.constant",
        "storage",
        "keyword"
      ],
      "settings": {
        "foreground": "#6699DD"
      }
    },

    // Regexp

    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#6B9FDD"
      }
    },

    // Operators, storage modifiers

    {
      "scope": ["keyword.operator", "storage.modifier"],
      "settings": {
        "foreground": "#50B050"
      }
    },

    // PHP

    {
      "scope": [
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php"
      ],
      "settings": {
        "foreground": "#C186B4"
      }
    },

    {
      "scope": ["support.function.construct.php"],
      "settings": {
        "fontStyle": ""
      }
    },

    // HTML/XML

    {
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end",
        "entity.name.tag",
        "entity.name.tag.block.any",
        "entity.name.tag.inline.any"
      ],
      "settings": {
        "foreground": "#6699DD"
      }
    },

    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#FF6060"
      }
    },

    // CSS

    {
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#6699DD"
      }
    },

    {
      "scope": [
        "meta.property-value.css keyword.other.unit",
        "meta.at-rule.media.header.css keyword.other.unit"
      ],
      "settings": {
        "foreground": "#FF6060"
      }
    },

    {
      "scope": [
        "meta.property-value.css support.constant",
        "meta.property-value.css constant"
      ],
      "settings": {
        "foreground": "#C8843A"
      }
    },

    {
      "scope": ["meta.property-value.css support.function"],
      "settings": {
        "fontStyle": ""
      }
    },

    // JSON

    {
      "scope": [
        "punctuation.support.type.property-name.begin.json",
        "punctuation.support.type.property-name.end.json"
      ],
      "settings": {
        "foreground": "#AAAAAA"
      }
    },

    {
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#C8843A"
      }
    },

    {
      "scope": ["string.quoted.double.json"],
      "settings": {
        "foreground": "#AAAAAA"
      }
    },

    {
      "scope": ["constant.numeric.json"],
      "settings": {
        "foreground": "#FF6060"
      }
    },

    {
      "scope": ["constant.language.json"],
      "settings": {
        "foreground": "#6699DD"
      }
    },

    {
      "scope": [
        "punctuation.definition.dictionary.begin.json",
        "punctuation.definition.dictionary.end.json",
        "punctuation.definition.array.begin.json",
        "punctuation.definition.array.end.json"
      ],
      "settings": {
        "foreground": "#50B050"
      }
    },

    // SQL

    {
      "scope": [
        "keyword.other.sql",
        "keyword.other.create.sql",
        "keyword.other.DML.sql",
        "keyword.other.DML.II.sql",
        "keyword.other.postgres",
        "keyword.other.sql.postgres",
        "keyword.control.postgres"
      ],
      "settings": {
        "foreground": "#C8843A"
      }
    }
  ]
}
